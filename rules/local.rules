alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"LOCAL ICMP ping detected"; itype:8; classtype:icmp-event; sid:100001; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"LOCAL possible TCP SYN scan"; flags:S; detection_filter:track by_src, count 10, seconds 5; classtype:attempted-recon; sid:100002; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 23 (msg:"LOCAL Telnet connection attempt"; flags:S; classtype:attempted-admin; sid:100003; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"LOCAL FTP connection attempt"; flags:S; classtype:attempted-recon; sid:100004; rev:2;)
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"LOCAL possible directory traversal /etc/passwd request"; flow:to_server,established; content:"/etc/passwd"; http_uri; classtype:web-application-attack; sid:100005; rev:2;)
